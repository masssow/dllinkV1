<header class="dl-site-header sticky-top bg-white border-bottom">
    <nav class="navbar navbar-expand-lg navbar-light py-3">
        <div class="container">

            <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_home') }}">
                {# <img
                    src="{{ asset('images/logo-dahiralink-icon.svg') }}"
                    alt="DahiraLink"
                    class="dl-navbar-logo"
                > #}
                <div class="d-flex flex-column lh-sm">
                    <span class="fw-bold dl-brand-name">DahiraLink</span>
                    <small class="text-muted d-none d-sm-block">Duas & khatms du Coran collectives</small>
                </div>
            </a>

            <button class="navbar-toggler border-0 shadow-none px-2" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Ouvrir la navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse mt-3 mt-lg-0" id="mainNavbar">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="{{ path('app_home') }}">Accueil</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="{{ path('app_quran_session_new') }}">Créer un khatm</a>
                    </li>

                    <li class="nav-item">
                        {# <a class="nav-link fw-medium" href="#">Rejoindre</a> #}
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="{{ path('app_about') }}">À propos</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="{{ path('app_contact') }}">Contact</a>
                    </li>

                    <li class="nav-item ms-lg-3 mt-3 mt-lg-0">
                        {% if app.user %}
                            <a class="btn btn-success rounded-pill px-4 w-100 w-lg-auto" href="{{ path('app_account') }}">
                                Mon compte
                            </a>
                        {% else %}
                            <a class="btn btn-success rounded-pill px-4 w-100 w-lg-auto" href="{{ path('app_login') }}">
                                Se connecter
                            </a>
                        {% endif %}
                    </li>

                </ul>
            </div>

        </div>
    </nav>
</header>