<div class="text-center p-4 bg-white rounded-4 shadow-sm h-100">

    {# Icône image prioritaire #}
    {% if icon_path is defined %}
        <div class="mb-3">
            <img 
                src="{{ asset(icon_path) }}"
                alt=""
                width="40"
                height="40"
                class="img-fluid"
                style="object-fit: contain;"
                loading="lazy"
            >
        </div>
    {% endif %}

    {# Fallback si jamais tu passes encore un emoji #}
    {% if icon is defined and icon_path is not defined %}
        <div class="mb-3 fs-2">
            {{ icon }}
        </div>
    {% endif %}

    <h5 class="fw-bold mb-2">{{ title }}</h5>
    <p class="text-muted small mb-0">
        {{ text }}
    </p>

</div>