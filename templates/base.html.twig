<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}DahiraLink{% endblock %}</title>

    {# SEO #}
    <meta name="description" content="{% block meta_description %}DahiraLink facilite l’organisation des khatms et des lectures collectives déjà partagées sur WhatsApp, sans changer les habitudes de votre dahira.{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index,follow{% endblock %}">

    {# Open Graph #}
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{% block og_title %}{% block title_fallback %}DahiraLink{% endblock %}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{% block meta_description_fallback %}DahiraLink facilite l’organisation des kaamils et des durus collectives déjà partagées sur WhatsApp.{% endblock %}{% endblock %}">
    <meta property="og:url" content="{% block og_url %}{{ app.request.uri }}{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('images/og-default-dahiralink.png')) }}{% endblock %}">
    <meta property="og:site_name" content="DahiraLink">

    {# Twitter #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}{% block title_fallback_2 %}DahiraLink{% endblock %}{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}{% block meta_description_fallback_2 %}DahiraLink facilite l’organisation des khatms et des lectures collectives déjà partagées sur WhatsApp.{% endblock %}{% endblock %}">
    <meta name="twitter:image" content="{% block twitter_image %}{{ absolute_url(asset('images/og-default-dahiralink.png')) }}{% endblock %}">

    {# Favicons #}
    <link rel="icon" type="image/x-icon" href="{{ asset('images/icons/favicon.ico') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('images/icons/favicon-32x32.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('images/icons/apple-touch-icon.png') }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ asset('images/icons/android-chrome-192x192.png') }}">
    <link rel="icon" type="image/png" sizes="512x512" href="{{ asset('images/icons/android-chrome-512x512.png') }}">
    <meta name="theme-color" content="#198754">

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>

<body>

    {# Header #}
    {% include 'partials/_header.html.twig' %}

    {# Cookie Banner #}
    {% include 'partials/_cookie_banner.html.twig' %}

    {# Flash Messages #}
    <div class="container mt-3">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                {% set alertClass = 'alert-info' %}

                {% if label in ['error', 'danger'] %}
                    {% set alertClass = 'alert-danger' %}
                {% elseif label == 'success' %}
                    {% set alertClass = 'alert-success' %}
                {% elseif label == 'warning' %}
                    {% set alertClass = 'alert-warning' %}
                {% endif %}

                <div class="alert {{ alertClass }} alert-dismissible fade show rounded-3 shadow-sm mb-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% block body %}{% endblock %}

    {# Footer #}
    {% include 'partials/_footer.html.twig' %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
        {% block importmap %}{% endblock %}
    {% endblock %}
</body>
</html>