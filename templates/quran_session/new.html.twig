{% extends 'base.html.twig' %}

{% block title %}Créer une session — DahiraLink{% endblock %}

{% block body %}
<section class="py-5 bg-light">
    <div class="container" style="max-width: 760px;">

        <div class="text-center mb-4">
            <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2 mb-3">
                Créer une session d'adoration collective
            </span>

            {# <h1 class="fw-bold mb-3">Organiser une lecture ou une Zikr collective</h1> #}

            <p class="text-muted mb-0">
                Lancez simplement un khatm ou une session de du‘a, zikr ou khassaides,
                puis partagez le lien avec votre dahira ou vos proches.
            </p>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
            {{ form_start(form, { attr: { class: 'dl-session-form', novalidate: 'novalidate' } }) }}
            {{ form_errors(form) }}
                <div class="mb-4">
                    {{ form_row(form.title) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.type) }}
                </div>

                <div id="khatm-info-block" class="dl-type-panel dl-type-panel--khatm mb-4">
                    <div class="rounded-4 border bg-success-subtle p-3">
                        <h6 class="fw-semibold mb-2">Lecture collective du Coran</h6>
                        <p class="mb-0 text-muted small">
                            Cette session créera automatiquement les 30 hizb du khatm,
                            afin que chacun puisse prendre sa part facilement.
                        </p>
                    </div>
                </div>

                <div id="dua-fields-block" class="dl-type-panel dl-type-panel--dua">
                    <div class="mb-4">
                        {{ form_row(form.duaLabel) }}
                    </div>

                    <div class="mb-4">
                        {{ form_row(form.totalTarget) }}
                    </div>

                    <div class="mb-4">
                        {{ form_row(form.expiresAt) }}
                    </div>
                </div>

                <div class="mb-4">
                    {{ form_row(form.description) }}
                </div>

                <div class="mb-4">
                    {{ form_row(form.imageFile) }}
                    <p class="text-center text-muted small mt-3 mb-0">
                       <strong>Conseil :</strong> utilisez une image horizontale claire ou sobre pour un meilleur rendu sur le lien partagé.
                    </p>
                </div>


                <div class="mb-4">
                    {{ form_row(form.scheduledAt) }}
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success btn-lg rounded-pill py-3">
                        Créer ma session
                    </button>
                </div>

                <p class="text-center text-muted small mt-3 mb-0">
                    Vous pourrez ensuite partager le lien dans WhatsApp, Telegram ou autre. Pour permettre
                    à chacun de participer facilement.
                </p>

            {{ form_end(form) }}
        </div>
    </div>
</section>
{% endblock %}