{% extends 'base.html.twig' %}

{% block title %}{{ session.title }} — DahiraLink{% endblock %}

{% block meta_description %}
    {% if session is defined and session.description %}
        {{ session.description|striptags|u.truncate(155, '...') }}
    {% elseif session is defined and session.type == 'khatm' %}
        Participez à ce khatm collectif sur DahiraLink.
    {% elseif session is defined and session.type == 'dua' %}
        Participez à cette session de du‘a / zikr collective sur DahiraLink.
    {% else %}
        Avec DahiraLink - Organisez vos sessions de lecture du Quraan.
    {% endif %}
{% endblock %}

{% block og_type %}website{% endblock %}

{% block og_title %}
    {% if session is defined and session.title %}
        {{ session.title }} — DahiraLink
    {% else %}
        DahiraLink
    {% endif %}
{% endblock %}

{% block og_description %}
    {% if session is defined and session.description %}
        {{ session.description|striptags|u.truncate(180, '...') }}
    {% elseif session is defined and session.type == 'khatm' %}
        Rejoignez ce khatm collectif et prenez votre part facilement.
    {% elseif session is defined and session.type == 'dua' %}
        Rejoignez cette session de du‘a / zikr collective et participez simplement.
    {% else %}
        Participez à cette session spirituelle sur DahiraLink.
    {% endif %}
{% endblock %}

{% block og_url %}
    {% if session is defined %}
        {{ absolute_url(path('app_quran_session_public_show', {slug: session.slug})) }}
    {% endif %}
{% endblock %}

{% block og_image %}
    {% if session is defined and session.imageName %}
    {{ ogImage }}
    {% else %}
    {{ absolute_url(asset('images/og-default-dahiralink.png')) }}
    {% endif %}
{% endblock %}


{% block body %}
<div class="dl-public-session-page">

    <section class="py-4 py-md-5 bg-light">
        <div class="container" style="max-width: 920px;">

            {% include 'quran_session/public/_hero.html.twig' %}
            {% include 'quran_session/public/_progress.html.twig' %}

            {% if isGoalReached %}
                {% include 'quran_session/public/_goal_reached.html.twig' %}
            {% endif %}

            {% if session.type == 'khatm' %}
                {% include 'quran_session/public/_khatm_section.html.twig' %}
            {% elseif session.type == 'dua' %}
                {% include 'quran_session/public/_dua_section.html.twig' %}
            {% endif %}

        </div>
    </section>

</div>

{% if session.type == 'khatm' %}
    <script>
        window.khatmConfig = {
            sessionSlug: "{{ session.slug }}",
            sessionStateUrl: "{{ path('app_session_state', {slug: session.slug}) }}"
        };
    </script>
{% endif %}
{% endblock %}