{% extends 'base.html.twig' %}

{% block title %}Se connecter — DahiraLink{% endblock %}

{% block body %}
<section class="dl-auth-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-xl-5">

                <div class="text-center mb-4">
                    <img
                        src="{{ asset('images/logo-dahiralink.png') }}"
                        alt="DahiraLink"
                        class="dl-auth-logo mb-3" style="max-width: 150px; height: auto;"
                    >

                    <span class="badge rounded-pill px-3 py-2 mb-3 text-bg-success-subtle text-success fw-semibold">
                        Heureux de vous revoir
                    </span>

                    <h1 class="fw-bold mb-3">Se connecter</h1>

                    <p class="text-muted mb-0">
                        Retrouvez vos sessions, vos participations et vos initiatives
                        dans un espace simple et accessible.
                    </p>
                </div>

                <div class="dl-auth-card shadow-sm rounded-4 p-4 p-md-5 bg-white">

                    {% if error %}
                        <div class="alert alert-danger rounded-4 mb-4">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-success rounded-4 mb-4">
                            Vous êtes déjà connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>,
                            <a href="{{ logout_path() }}" class="fw-semibold text-decoration-none">se déconnecter</a>.
                        </div>
                    {% endif %}

                    <form method="post" class="dl-form">

                        <div class="dl-field mb-3">
                            <label for="inputEmail" class="form-label fw-semibold">Adresse e-mail</label>
                            <input
                                type="email"
                                value="{{ last_username }}"
                                name="email"
                                id="inputEmail"
                                class="form-control dl-input"
                                placeholder="exemple@email.com"
                                autocomplete="email"
                                required
                                autofocus
                            >
                        </div>

                        <div class="dl-field mb-3">
                            <label for="inputPassword" class="form-label fw-semibold">Mot de passe</label>
                            <input
                                type="password"
                                name="password"
                                id="inputPassword"
                                class="form-control dl-input"
                                placeholder="Votre mot de passe"
                                autocomplete="current-password"
                                required
                            >
                        </div>

                        <input
                            type="hidden"
                            name="_csrf_token"
                            value="{{ csrf_token('authenticate') }}"
                        >

                        <div class="small text-muted text-center mb-3">
                            Accès simple - Participation fluide - Partage facile
                        </div>

                        <button class="btn btn-success btn-lg w-100 rounded-pill py-3 fw-semibold mt-2" type="submit">
                            Se connecter
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted mb-0">
                            Vous n’avez pas encore de compte ?
                            <a href="{{ path('app_registration') }}" class="fw-semibold text-success text-decoration-none">
                                Créer un compte
                            </a>
                        </p>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <h5 class=" text-muted mb-0">
                        DahiraLink
                    </h5>
                </div>

            </div>
        </div>
    </div>
</section>
{% endblock %}