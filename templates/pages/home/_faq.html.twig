<section class="py-5 bg-light">
    <div class="container">

        {% include 'components/_section_heading.html.twig' with {
            eyebrow: 'Questions fréquentes',
            title: 'Ce qu’il faut savoir',
            text: ''
        } %}

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="homeFaqAccordion">

                    <!-- Question 1 -->
                    <div class="accordion-item border rounded-4 mb-3 overflow-hidden">
                        <h2 class="accordion-header" id="faqOneHeading">
                            <button class="accordion-button collapsed fw-semibold" type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqOne"
                                    aria-expanded="false"
                                    aria-controls="faqOne">
                                DahiraLink remplace-t-il WhatsApp ?
                            </button>
                        </h2>
                        <div id="faqOne"
                             class="accordion-collapse collapse"
                             aria-labelledby="faqOneHeading"
                             data-bs-parent="#homeFaqAccordion">
                            <div class="accordion-body text-muted">
                                Non. DahiraLink fonctionne avec vos groupes existants.
                                Il simplifie la création des khatms en évitant
                                les listes écrites manuellement et les emojis bricolés
                                pour marquer les hizb terminés.
                            </div>
                        </div>
                    </div>

                    <!-- Question 2 -->
                    <div class="accordion-item border rounded-4 mb-3 overflow-hidden">
                        <h2 class="accordion-header" id="faqTwoHeading">
                            <button class="accordion-button collapsed fw-semibold" type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqTwo"
                                    aria-expanded="false"
                                    aria-controls="faqTwo">
                                Faut-il créer un compte pour lancer un khatm ?
                            </button>
                        </h2>
                        <div id="faqTwo"
                             class="accordion-collapse collapse"
                             aria-labelledby="faqTwoHeading"
                             data-bs-parent="#homeFaqAccordion">
                            <div class="accordion-body text-muted">
                                Oui. Un compte est nécessaire pour créer un khatm
                                et retrouver l’historique de vos sessions.
                            </div>
                        </div>
                    </div>

                    <!-- Question 3 -->
                    <div class="accordion-item border rounded-4 overflow-hidden">
                        <h2 class="accordion-header" id="faqThreeHeading">
                            <button class="accordion-button collapsed fw-semibold" type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqThree"
                                    aria-expanded="false"
                                    aria-controls="faqThree">
                                Faut-il un compte pour participer ?
                            </button>
                        </h2>
                        <div id="faqThree"
                             class="accordion-collapse collapse"
                             aria-labelledby="faqThreeHeading"
                             data-bs-parent="#homeFaqAccordion">
                            <div class="accordion-body text-muted">
                                Non. Un simple lien partagé suffit pour rejoindre
                                un khatm et choisir sa participation.
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>