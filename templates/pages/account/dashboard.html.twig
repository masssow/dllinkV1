{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}

<div class="container mt-4">

<h2>Mon compte</h2>

{% include 'components/dashboard_stats.html.twig' %}

<hr>

<h4>Mes sessions</h4>

<div class="row">

{% for session in sessions %}

<div class="col-md-6 mb-3">

{% include 'components/session_card.html.twig' with {session: session} %}

</div>

{% endfor %}

</div>

<div class="mt-4 text-center">

<a href="{{ path('app_session_create') }}" class="btn btn-primary">
Créer une session
</a>

</div>

</div>

{% endblock %}